# Copy this file to .env and fill in your own values:
#
#     cp .env.example .env
#
# The application loads .env automatically at startup (see DotEnvConfig), so you
# do NOT need to set these as operating-system environment variables.
# Anything left unset here falls back to the defaults in application.properties.

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
chai_spring_port=8080
chai_spring_host_url=http://localhost:8080

# ----------------------------------------------------------------------------
# Database — default: SQLite (no DB server needed; data is stored in ./chai.db)
# ----------------------------------------------------------------------------
chai_spring_datasource_url=jdbc:sqlite:./chai.db
chai_spring_datasource_username=
chai_spring_datasource_password=
chai_spring_datasource_driver_class_name=org.sqlite.JDBC

# To use MySQL instead, comment out the SQLite block above and use these:
# chai_spring_datasource_url=jdbc:mysql://localhost:3306/chai
# chai_spring_datasource_username=root
# chai_spring_datasource_password=your_password
# chai_spring_datasource_driver_class_name=com.mysql.cj.jdbc.Driver

# ----------------------------------------------------------------------------
# Email — used to send the passwordless magic-link login emails.
# Leave blank to skip configuring mail (login emails will fail to send).
# ----------------------------------------------------------------------------
chai_spring_email_from=noreply@chaihq.com
chai_spring_mail_host=
chai_spring_mail_port=587
chai_spring_mail_username=
chai_spring_mail_password=
